generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  email       String   @unique
  password    String
  phoneNumber String?
  image       String?
  role        String   @default("user")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Warehouse {
  id          Int       @id @default(autoincrement())
  name        String
  email       String?
  phoneNumber String?
  country     String?
  city        String?
  zipCode     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Soft-delete: null = active, non-null = deleted.
  // Hard-deletes are intentionally avoided because warehouses will be
  // referenced by stock, sales, and purchases records.
  deletedAt   DateTime?

  @@index([deletedAt])
}

model Supplier {
  id          Int       @id @default(autoincrement())
  name        String
  email       String?
  phoneNumber String?
  country     String?
  city        String?
  address     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Soft-delete: null = active, non-null = deleted.
  // Hard-deletes are avoided because suppliers will be referenced by purchases.
  deletedAt   DateTime?

  @@index([deletedAt])
}

model Customer {
  id          Int       @id @default(autoincrement())
  name        String
  email       String?
  phoneNumber String?
  dateOfBirth DateTime?
  country     String?
  city        String?
  // TEXT column — addresses can be multi-line and exceed VARCHAR(191).
  address     String?   @db.Text
  // Marks the protected walk-in / POS default customer ("direct-customer").
  // This record must never be soft-deleted; it is created by the seed script.
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Soft-delete: null = active, non-null = deleted.
  // Hard-deletes avoided because customers are referenced by sales/quotations.
  deletedAt   DateTime?

  @@index([deletedAt])
  @@index([isDefault])
}
